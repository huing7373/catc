# Example local override config — copy to local.toml (gitignored) and adjust.
# Only the keys you want to override; missing sections fall back to default.toml.

[server]
host = "0.0.0.0"
port = 8080
tls = false
mode = "debug"

[log]
level = "info"
output = "stdout"

[mongo]
uri = "mongodb://localhost:27017"
db = "catdb"

[redis]
addr = "localhost:6379"
db = 0

[jwt]
private_key_path = ""
active_kid = ""
issuer = "cat"
access_expiry_sec = 900
refresh_expiry_sec = 2592000

[apns]
# Set enabled = true and fill key_id / team_id / bundle_id / key_path
# only when you want to drive a real APNs HTTP/2 connection from local.
enabled = false
key_id = ""
team_id = ""
bundle_id = ""
key_path = ""
watch_topic = ""
iphone_topic = ""

[apple]
# bundle_id is the `aud` claim that every accepted Apple identity token
# must carry — must match the app's Bundle Identifier in Xcode. Required:
# leaving it empty makes the server log.Fatal at startup (review-
# antipatterns §4.1). For dev builds use the development bundle ID; for
# release set the production one in production.toml.
# bundle_id = "com.huing.cat.dev"

[cdn]
base_url = ""
